{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "outDir": ".test-dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "tests/run-regressions.ts",
    "lib/invoice.ts",
    "lib/businessProfile.ts",
    "lib/invoiceNumber.ts",
    "lib/invoicePrefixValidation.ts",
    "lib/logoStorage.ts",
    "lib/server/invoicePdfExportCache.ts"
  ]
}
