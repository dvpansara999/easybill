{
  "name": "invoice-app",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:regression": "tsc -p tsconfig.tests.json && node -e \"const fs=require('fs');fs.copyFileSync('.test-dist/lib/businessProfile.js','.test-dist/lib/businessProfile');\" && node .test-dist/tests/run-regressions.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "verify": "npm run lint && npm run typecheck && npm run test:regression",
    "pdf:help": "node -e \"console.log('PDF: POST /api/invoice-pdf (Playwright setContent). See docs/PDF-PIPELINE.md')\""
  },
  "dependencies": {
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "^16.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}

