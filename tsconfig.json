{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-playwright/types/**/*.ts",
    ".next-playwright/dev/types/**/*.ts",
    ".next-playwright-e2e/types/**/*.ts",
    ".next-playwright-e2e/dev/types/**/*.ts",
    ".next-playwright-e2e-10460-mn76z809/types/**/*.ts",
    ".next-playwright-e2e-10460-mn76z809/dev/types/**/*.ts",
    ".next-playwright-e2e-14448-mn779ury/types/**/*.ts",
    ".next-playwright-e2e-14448-mn779ury/dev/types/**/*.ts",
    ".next-playwright-e2e-3472-mn78pl9d/types/**/*.ts",
    ".next-playwright-e2e-3472-mn78pl9d/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/e2e/**/*",
    "playwright.config.ts"
  ]
}
